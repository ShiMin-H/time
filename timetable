<!DOCTYPE html>

<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>時間割 · 課表</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;600&family=Noto+Sans+TC:wght@300;400;500&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
/* ── WABI-SABI JAPANESE PALETTE ── */
:root {
  --shiro:    #f5f2ec;   /* 白 warm white */
  --gofun:    #ede8df;   /* 胡粉 off-white */
  --washi:    #e8e2d6;   /* 和紙 */
  --nezumi:   #9e9b95;   /* 鼠 warm grey */
  --sumi:     #3d3b37;   /* 墨 ink */
  --sumi2:    #6b6760;   /* lighter ink */
  --kohaku:   #c9956c;   /* 琥珀 amber */
  --moegi:    #7a9e7e;   /* 萌黄 muted green */
  --hanada:   #7394b0;   /* 縹 muted blue */
  --kurenai:  #b5706a;   /* 紅 muted red */
  --fuji:     #9b8fb5;   /* 藤 wisteria */
  --tsuchi:   #b3a48a;   /* 土 earth */
  --usucha:   #a89a7c;   /* 薄茶 */
  --karashi:  #c4ad6e;   /* 芥子 mustard */
  --border:   rgba(61,59,55,0.10);
  --border2:  rgba(61,59,55,0.06);
  --shadow:   0 2px 20px rgba(61,59,55,0.08);
  --shadow2:  0 8px 40px rgba(61,59,55,0.13);
  --r:        10px;
  --r2:       16px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
height: 100%;
font-family: ‘Noto Sans TC’, sans-serif;
background: var(–shiro);
color: var(–sumi);
overflow: hidden;
}

/* ── PAGE SYSTEM ── */
.page {
position: fixed; inset: 0;
opacity: 0; pointer-events: none;
transition: opacity 0.35s ease, transform 0.35s ease;
overflow-y: auto;
}
.page.active {
opacity: 1; pointer-events: all;
transform: none !important;
}
#page-main { transform: translateX(-20px); }
#page-settings { transform: translateX(20px); background: var(–gofun); }

/* ── NAV BAR ── */
.nav {
position: sticky; top: 0; z-index: 50;
display: flex; align-items: center; justify-content: space-between;
padding: 14px 24px;
background: rgba(245,242,236,0.88);
backdrop-filter: blur(14px);
border-bottom: 1px solid var(–border);
}
.nav-logo {
font-family: ‘Noto Serif TC’, serif;
font-size: 1.1rem; font-weight: 600;
letter-spacing: 0.08em;
color: var(–sumi);
display: flex; align-items: center; gap: 8px;
}
.nav-logo .kanji {
font-size: 0.7rem; color: var(–nezumi);
font-family: ‘DM Mono’, monospace;
letter-spacing: 0.15em; text-transform: uppercase;
}
.nav-actions { display: flex; gap: 8px; align-items: center; }
.nav-btn {
padding: 7px 16px; border-radius: 30px;
border: 1px solid var(–border);
background: transparent;
font-size: 0.75rem; font-family: ‘Noto Sans TC’, sans-serif;
color: var(–sumi2); cursor: pointer;
transition: all 0.2s; letter-spacing: 0.03em;
font-weight: 400;
}
.nav-btn:hover { background: var(–washi); color: var(–sumi); border-color: var(–nezumi); }
.nav-btn.accent {
background: var(–sumi); color: var(–shiro);
border-color: var(–sumi);
}
.nav-btn.accent:hover { background: var(–sumi2); }
.nav-btn.settings-btn {
display: flex; align-items: center; gap: 5px;
background: var(–kohaku); color: #fff; border-color: var(–kohaku);
font-size: 0.72rem;
}
.nav-btn.settings-btn:hover { background: #b5845a; }

/* ── MAIN VIEW ── */
.main-body { padding: 20px 24px 40px; }

/* week selector strip */
.week-strip {
display: flex; gap: 6px; margin-bottom: 20px;
overflow-x: auto; padding-bottom: 4px;
}
.week-strip::-webkit-scrollbar { display: none; }
.week-chip {
flex-shrink: 0;
padding: 6px 14px; border-radius: 20px;
font-size: 0.73rem; cursor: pointer;
border: 1px solid var(–border);
background: transparent; color: var(–nezumi);
transition: all 0.18s; font-family: ‘Noto Sans TC’, sans-serif;
}
.week-chip:hover { background: var(–washi); color: var(–sumi); }
.week-chip.active { background: var(–sumi); color: var(–shiro); border-color: var(–sumi); }

/* timetable */
.tt-scroll { overflow-x: auto; }
table.tt {
width: 100%; border-collapse: separate; border-spacing: 3px;
min-width: 500px;
}
table.tt th {
font-size: 0.68rem; font-weight: 500; text-align: center;
padding: 8px 4px; color: var(–nezumi); letter-spacing: 0.08em;
font-family: ‘Noto Serif TC’, serif;
}
table.tt th.th-time { width: 56px; }
.time-cell {
text-align: right; padding-right: 10px;
vertical-align: top; padding-top: 10px;
}
.time-cell .t-period {
font-family: ‘DM Mono’, monospace;
font-size: 0.62rem; color: var(–nezumi);
display: block; line-height: 1;
}
.time-cell .t-time {
font-family: ‘DM Mono’, monospace;
font-size: 0.58rem; color: var(–tsuchi);
display: block; margin-top: 2px;
}
table.tt td.slot {
height: 62px; border-radius: var(–r);
border: 1.5px dashed rgba(61,59,55,0.13);
background: rgba(232,226,214,0.30);
vertical-align: middle; text-align: center;
cursor: pointer; transition: all 0.18s;
position: relative; min-width: 78px;
}
table.tt td.slot.empty:hover {
border-color: var(–kohaku);
background: rgba(201,149,108,0.08);
}
table.tt td.slot.filled {
border: none; cursor: default;
}
table.tt td.slot.drag-over {
border-color: var(–kohaku) !important;
background: rgba(201,149,108,0.12) !important;
transform: scale(0.96);
}
.slot-inner {
width: 100%; height: 100%; border-radius: calc(var(–r) - 1px);
display: flex; flex-direction: column; align-items: center;
justify-content: center; gap: 2px;
padding: 6px 4px;
position: relative; overflow: hidden;
}
.slot-inner::after {
content: ‘’;
position: absolute; inset: 0;
background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, transparent 60%);
pointer-events: none;
}
.slot-name {
font-size: 0.76rem; font-weight: 500;
line-height: 1.2; text-align: center;
font-family: ‘Noto Serif TC’, serif;
}
.slot-room {
font-size: 0.59rem; opacity: 0.7;
font-family: ‘DM Mono’, monospace;
letter-spacing: 0.05em;
}
.slot-time-tag {
font-size: 0.55rem; opacity: 0.6;
font-family: ‘DM Mono’, monospace;
}
.slot-del {
position: absolute; top: 4px; right: 4px;
width: 15px; height: 15px;
background: rgba(0,0,0,0.18); border-radius: 50%;
display: flex; align-items: center; justify-content: center;
font-size: 0.5rem; color: #fff;
opacity: 0; transition: opacity 0.15s;
cursor: pointer; border: none;
z-index: 2;
}
.slot-inner:hover .slot-del { opacity: 1; }
.slot-plus { font-size: 1rem; color: rgba(61,59,55,0.18); pointer-events: none; }

/* export zone */
.export-bar {
margin-top: 24px; padding: 14px 18px;
background: var(–gofun); border-radius: var(–r2);
border: 1px solid var(–border);
display: flex; align-items: center; justify-content: space-between;
flex-wrap: wrap; gap: 10px;
}
.export-bar span {
font-size: 0.78rem; color: var(–sumi2);
font-family: ‘Noto Serif TC’, serif;
}
.export-btns { display: flex; gap: 8px; }

/* ── SETTINGS PAGE ── */
#page-settings .nav {
background: rgba(237,232,223,0.90);
}
.settings-body {
padding: 24px; max-width: 860px; margin: 0 auto;
display: grid; grid-template-columns: 1fr 1fr; gap: 18px;
}
@media(max-width:640px){ .settings-body { grid-template-columns: 1fr; } }

.card {
background: var(–shiro);
border-radius: var(–r2);
border: 1px solid var(–border);
padding: 20px; box-shadow: var(–shadow);
}
.card.full { grid-column: 1/-1; }
.card-title {
font-family: ‘Noto Serif TC’, serif;
font-size: 0.85rem; font-weight: 600;
letter-spacing: 0.1em; color: var(–sumi);
margin-bottom: 14px;
padding-bottom: 10px; border-bottom: 1px solid var(–border);
display: flex; align-items: center; gap: 6px;
}

/* course pool */
.pool-list { display: flex; flex-direction: column; gap: 6px; min-height: 40px; }
.pool-chip {
display: flex; align-items: center; gap: 8px;
padding: 9px 12px; border-radius: 9px;
font-size: 0.78rem; cursor: grab;
user-select: none; transition: all 0.15s;
border: 1px solid transparent;
}
.pool-chip:hover { transform: translateX(3px); box-shadow: var(–shadow); }
.pool-chip:active { cursor: grabbing; }
.pool-chip.dragging { opacity: 0.4; }
.pool-chip .c-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; background: rgba(255,255,255,0.5); }
.pool-chip .c-name { font-weight: 500; flex: 1; font-family: ‘Noto Serif TC’, serif; }
.pool-chip .c-room { font-size: 0.68rem; font-family: ‘DM Mono’, monospace; opacity: 0.7; }
.pool-chip .c-del {
width: 18px; height: 18px; border-radius: 50%;
background: rgba(0,0,0,0.15); border: none;
display: flex; align-items: center; justify-content: center;
font-size: 0.58rem; color: #fff; cursor: pointer;
opacity: 0; transition: opacity 0.15s;
}
.pool-chip:hover .c-del { opacity: 1; }

.add-form { display: flex; flex-direction: column; gap: 8px; margin-top: 12px; }
.add-form input {
padding: 9px 12px; border-radius: 9px;
border: 1.5px solid var(–border);
background: var(–gofun); font-size: 0.78rem;
font-family: ‘Noto Sans TC’, sans-serif;
color: var(–sumi); outline: none; transition: border 0.15s;
width: 100%;
}
.add-form input:focus { border-color: var(–kohaku); background: #fff; }
.add-form input::placeholder { color: var(–nezumi); }

/* color palette — jp muted */
.jp-colors { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 4px; }
.jp-swatch {
width: 26px; height: 26px; border-radius: 50%; cursor: pointer;
border: 2px solid transparent; transition: all 0.15s;
position: relative;
}
.jp-swatch:hover { transform: scale(1.2); }
.jp-swatch.sel { border-color: var(–sumi); transform: scale(1.15); }
.jp-swatch.sel::after {
content: ‘✓’; position: absolute; inset: 0;
display: flex; align-items: center; justify-content: center;
font-size: 0.55rem; color: rgba(0,0,0,0.5);
}

/* time settings */
.time-slots-list { display: flex; flex-direction: column; gap: 6px; }
.time-row {
display: flex; align-items: center; gap: 8px;
padding: 8px 10px; border-radius: 9px;
background: var(–gofun); border: 1px solid var(–border);
font-size: 0.75rem;
}
.time-row .tr-period {
font-family: ‘DM Mono’, monospace; color: var(–nezumi);
width: 20px; text-align: center; flex-shrink: 0;
}
.time-row input[type=time] {
padding: 3px 6px; border-radius: 6px;
border: 1px solid var(–border); background: #fff;
font-family: ‘DM Mono’, monospace; font-size: 0.73rem;
color: var(–sumi); outline: none; cursor: pointer;
}
.time-row input[type=time]:focus { border-color: var(–kohaku); }
.time-row .tr-sep { color: var(–nezumi); font-size: 0.7rem; }
.time-row .tr-del {
margin-left: auto; width: 18px; height: 18px;
border-radius: 50%; background: var(–border);
border: none; display: flex; align-items: center; justify-content: center;
font-size: 0.55rem; color: var(–sumi2); cursor: pointer;
transition: background 0.15s;
}
.time-row .tr-del:hover { background: var(–kurenai); color: #fff; }
.time-add-btn {
margin-top: 6px; padding: 7px; border-radius: 9px;
border: 1.5px dashed var(–border); background: transparent;
font-size: 0.72rem; color: var(–nezumi); cursor: pointer;
width: 100%; font-family: ‘Noto Sans TC’, sans-serif;
transition: all 0.15s;
}
.time-add-btn:hover { border-color: var(–kohaku); color: var(–kohaku); background: rgba(201,149,108,0.05); }

/* day & display settings */
.toggle-row { display: flex; flex-wrap: wrap; gap: 6px; }
.toggle-chip {
padding: 6px 14px; border-radius: 20px;
border: 1px solid var(–border); background: transparent;
font-size: 0.72rem; cursor: pointer; color: var(–sumi2);
font-family: ‘Noto Sans TC’, sans-serif; transition: all 0.15s;
}
.toggle-chip:hover { background: var(–washi); }
.toggle-chip.on { background: var(–sumi); color: var(–shiro); border-color: var(–sumi); }

/* background picker */
.bg-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; }
@media(max-width:400px){ .bg-grid { grid-template-columns: repeat(3,1fr); } }
.bg-thumb {
aspect-ratio: 3/2; border-radius: 9px; cursor: pointer;
overflow: hidden; border: 2.5px solid transparent;
transition: all 0.18s; position: relative;
background-size: cover; background-position: center;
}
.bg-thumb:hover { transform: scale(1.04); }
.bg-thumb.on { border-color: var(–kohaku); }
.bg-thumb .bg-name {
position: absolute; bottom: 0; left: 0; right: 0;
background: linear-gradient(transparent, rgba(0,0,0,0.5));
color: #fff; font-size: 0.58rem; padding: 4px 5px 3px;
font-family: ‘Noto Serif TC’, serif;
}
.bg-upload-slot {
aspect-ratio: 3/2; border-radius: 9px; cursor: pointer;
border: 1.5px dashed var(–border);
display: flex; flex-direction: column; align-items: center;
justify-content: center; gap: 3px;
color: var(–nezumi); font-size: 0.6rem;
background: var(–gofun); transition: all 0.15s;
font-family: ‘Noto Sans TC’, sans-serif;
}
.bg-upload-slot:hover { border-color: var(–kohaku); color: var(–kohaku); }
.bg-upload-slot .icon { font-size: 1.2rem; }

/* note / label settings */
.label-row { display: flex; align-items: center; gap: 8px; font-size: 0.75rem; }
.label-row label { color: var(–sumi2); flex-shrink: 0; }
.label-row input {
flex: 1; padding: 7px 10px; border-radius: 8px;
border: 1.5px solid var(–border); background: var(–gofun);
font-size: 0.75rem; font-family: ‘Noto Serif TC’, serif;
color: var(–sumi); outline: none;
}
.label-row input:focus { border-color: var(–kohaku); background: #fff; }

/* ── MODAL ── */
.modal-mask {
position: fixed; inset: 0; z-index: 200;
background: rgba(40,38,35,0.40); backdrop-filter: blur(6px);
display: flex; align-items: center; justify-content: center;
opacity: 0; pointer-events: none; transition: opacity 0.25s;
}
.modal-mask.open { opacity: 1; pointer-events: all; }
.modal-box {
background: var(–shiro); border-radius: var(–r2);
padding: 26px; width: 320px; max-width: 92vw;
box-shadow: var(–shadow2);
transform: translateY(16px) scale(0.97);
transition: transform 0.25s;
border: 1px solid var(–border);
}
.modal-mask.open .modal-box { transform: none; }
.modal-box h3 {
font-family: ‘Noto Serif TC’, serif;
font-size: 0.92rem; margin-bottom: 16px;
color: var(–sumi);
}
.modal-box label {
display: block; font-size: 0.7rem; color: var(–nezumi);
margin-bottom: 5px; margin-top: 12px; letter-spacing: 0.05em;
}
.modal-box input, .modal-box select {
width: 100%; padding: 9px 12px; border-radius: 9px;
border: 1.5px solid var(–border); background: var(–gofun);
font-size: 0.8rem; font-family: ‘Noto Sans TC’, sans-serif;
color: var(–sumi); outline: none; transition: border 0.15s;
}
.modal-box input:focus { border-color: var(–kohaku); background: #fff; }
.modal-btns { display: flex; gap: 8px; margin-top: 20px; }
.modal-btns button {
flex: 1; padding: 9px; border-radius: 30px;
border: 1px solid var(–border); cursor: pointer;
font-size: 0.75rem; font-family: ‘Noto Sans TC’, sans-serif;
transition: all 0.18s;
}
.modal-btns .m-cancel { background: transparent; color: var(–sumi2); }
.modal-btns .m-cancel:hover { background: var(–washi); }
.modal-btns .m-ok { background: var(–sumi); color: var(–shiro); border-color: var(–sumi); }
.modal-btns .m-ok:hover { background: var(–sumi2); }

/* ── TOAST ── */
.toast {
position: fixed; bottom: 30px; left: 50%;
transform: translateX(-50%) translateY(50px);
background: var(–sumi); color: var(–shiro);
padding: 9px 22px; border-radius: 30px;
font-size: 0.75rem; z-index: 300;
transition: transform 0.28s; pointer-events: none;
font-family: ‘Noto Serif TC’, serif; letter-spacing: 0.05em;
white-space: nowrap;
}
.toast.show { transform: translateX(-50%) translateY(0); }

/* ── BG LAYER ── */
#bg-layer {
position: fixed; inset: 0; z-index: -1;
background-size: cover; background-position: center;
transition: all 0.6s ease;
}
#bg-overlay {
position: fixed; inset: 0; z-index: 0;
transition: background 0.5s;
pointer-events: none;
}
.page { z-index: 1; }

.empty-hint {
font-size: 0.72rem; color: var(–nezumi);
text-align: center; padding: 10px 0; font-style: italic;
}

/* range slider for today highlight */
.today-badge {
display: inline-block;
padding: 2px 8px; border-radius: 10px;
background: var(–kohaku); color: #fff;
font-size: 0.6rem; font-family: ‘DM Mono’, monospace;
margin-left: 4px; vertical-align: middle;
}
</style>

</head>
