// ══════════════════════════════════════
//  STATE
// ══════════════════════════════════════
const DAYS_ALL = ['一','二','三','四','五','六','日'];
let activeDays = [0,1,2,3,4]; // indices into DAYS_ALL

let timeSlots = [
  {start:'08:00',end:'08:50'},
  {start:'09:00',end:'09:50'},
  {start:'10:00',end:'10:50'},
  {start:'11:00',end:'11:50'},
  {start:'13:00',end:'13:50'},
  {start:'14:00',end:'14:50'},
  {start:'15:00',end:'15:50'},
  {start:'16:00',end:'16:50'},
];

let courses = []; // {id, name, room, colorIdx}
let schedule = {}; // key `d-s` → {name,room,colorIdx}
let selColorIdx = 0;   // settings color pick
let mColorIdx = 0;     // modal color pick
let pendingSlot = null;  // {d,s}
let pendingPickMode = null; // courseId to place
let dragCourseId = null;
let bgActive = 0;
let customBgDataUrl = null;

// ══════════════════════════════════════
//  NAVIGATION
// ══════════════════════════════════════
function goSettings() {
  document.getElementById('page-main').classList.remove('active');
  document.getElementById('page-settings').classList.add('active');
  renderSettings();
}
function goMain() {
  document.getElementById('page-settings').classList.remove('active');
  document.getElementById('page-main').classList.add('active');
  renderMain();
}

// ══════════════════════════════════════
//  MAIN PAGE RENDER
// ══════════════════════════════════════
function renderMain() {
  renderWeekStrip();
  renderTT();
}
function renderWeekStrip() {
  const strip = document.getElementById('weekStrip');
  const today = new Date().getDay(); // 0=sun
  const todayIdx = today === 0 ? 6 : today - 1; // convert to mon=0
  strip.innerHTML = '';
  activeDays.forEach(di => {
    const btn = document.createElement('div');
    btn.className = 'week-chip' + (di === todayIdx ? ' active' : '');
    btn.innerHTML = `週${DAYS_ALL[di]}${di === todayIdx ? '<span class="today-badge">今日</span>' : ''}`;
    strip.appendChild(btn);
  });
}
function renderTT() {
  const table = document.getElementById('ttTable');
  // header
  let html = '<thead><tr><th class="th-time"></th>';
  activeDays.forEach(di => {
    html += `<th>週${DAYS_ALL[di]}</th>`;
  });
  html += '</tr></thead><tbody>';

  timeSlots.forEach((ts, si) => {
    html += '<tr>';
    html += `<td class="time-cell">
      <span class="t-period">${si+1}</span>
      <span class="t-time">${ts.start}</span>
    </td>`;
    activeDays.forEach((di, col) => {
      const key = `${di}-${si}`;
      const entry = schedule[key];
      if (entry) {
        const c = JP_COLORS[entry.colorIdx] || JP_COLORS[0];
        html += `<td class="slot filled" data-key="${key}">
          <div class="slot-inner" style="background:${c.bg};color:${c.text}">
            <span class="slot-name">${entry.name}</span>
            ${entry.room ? `<span class="slot-room">${entry.room}</span>`:''}
            <span class="slot-time-tag">${ts.start}–${ts.end}</span>
            <button class="slot-del" onclick="removeSlot('${key}')">✕</button>
          </div>
        </td>`;
      } else {
        html += `<td class="slot empty" data-di="${di}" data-si="${si}" data-key="${key}" onclick="slotClick(${di},${si})">
          <span class="slot-plus">＋</span>
        </td>`;
      }
    });
    html += '</tr>';
  });
  html += '</tbody>';
  table.innerHTML = html;

  // drag-drop listeners
  table.querySelectorAll('td.slot.empty').forEach(td => {
    td.addEventListener('dragover', e => { e.preventDefault(); td.classList.add('drag-over'); });
    td.addEventListener('dragleave', () => td.classList.remove('drag-over'));
    td.addEventListener('drop', e => {
      e.preventDefault(); td.classList.remove('drag-over');
      if (dragCourseId !== null) {
        const di = parseInt(td.dataset.di), si = parseInt(td.dataset.si);
        placeCourse(dragCourseId, di, si);
      }
    });
  });
}

// ══════════════════════════════════════
//  SLOT INTERACTION
// ══════════════════════════════════════
function slotClick(di, si) {
  if (pendingPickMode !== null) {
    placeCourse(pendingPickMode, di, si);
    pendingPickMode = null;
    return;
  }
  openModal(di, si);
}
function placeCourse(courseId, di, si) {
  const c = courses.find(x => x.id === courseId);
  if (!c) return;
  schedule[`${di}-${si}`] = { name:c.name, room:c.room, colorIdx:c.colorIdx };
  renderTT(); toast(`「${c.name}」已放入週${DAYS_ALL[di]} 第${si+1}節`);
}
function removeSlot(key) { delete schedule[key]; renderTT(); }

// ══════════════════════════════════════
//  MODAL
// ══════════════════════════════════════
function openModal(di, si) {
  pendingSlot = { di, si };
  mColorIdx = 0;
  // populate select
  const sel = document.getElementById('mSelect');
  sel.innerHTML = '<option value="">── 手動輸入 ──</option>';
  courses.forEach(c => {
    const opt = document.createElement('option');
    opt.value = c.id;
    opt.textContent = c.name + (c.room ? ` (${c.room})` : '');
    sel.appendChild(opt);
  });
  document.getElementById('mName').value = '';
  document.getElementById('mRoom').value = '';
  document.getElementById('mTitle').textContent = `放入 週${DAYS_ALL[di]} 第${si+1}節`;
  buildColorPicker('mColorPicker', () => mColorIdx, v => { mColorIdx = v; });
  document.getElementById('modal').classList.add('open');
  setTimeout(() => document.getElementById('mName').focus(), 120);
}
function mSelectChange() {
  const sel = document.getElementById('mSelect');
  if (!sel.value) return;
  const c = courses.find(x => String(x.id) === String(sel.value));
  if (!c) return;
  document.getElementById('mName').value = c.name;
  document.getElementById('mRoom').value = c.room || '';
  mColorIdx = c.colorIdx;
  buildColorPicker('mColorPicker', () => mColorIdx, v => { mColorIdx = v; });
}
function confirmModal() {
  const name = document.getElementById('mName').value.trim();
  if (!name) { toast('請輸入課程名稱'); return; }
  const room = document.getElementById('mRoom').value.trim();
  const { di, si } = pendingSlot;
  schedule[`${di}-${si}`] = { name, room, colorIdx: mColorIdx };
  closeModal(); renderTT();
  toast(`已放入「${name}」`);
}
function closeModal() {
  document.getElementById('modal').classList.remove('open');
  pendingSlot = null;
}
document.getElementById('modal').addEventListener('click', e => {
  if (e.target === document.getElementById('modal')) closeModal();
});

// ══════════════════════════════════════
//  SETTINGS RENDER
// ══════════════════════════════════════
function renderSettings() {
  renderPool();
  renderTimeSlots();
  renderDayToggle();
  renderBgGrid();
  buildColorPicker('colorPicker', () => selColorIdx, v => { selColorIdx = v; });
}

// Course pool
function renderPool() {
  const pool = document.getElementById('coursePool');
  if (!courses.length) { pool.innerHTML = '<div class="empty-hint">尚無課程，請在下方新增</div>'; return; }
  pool.innerHTML = '';
  courses.forEach(c => {
    const col = JP_COLORS[c.colorIdx] || JP_COLORS[0];
    const chip = document.createElement('div');
    chip.className = 'pool-chip';
    chip.draggable = true;
    chip.dataset.id = c.id;
    chip.style.background = col.bg; chip.style.color = col.text;
    chip.innerHTML = `<div class="c-dot"></div>
      <span class="c-name">${c.name}</span>
      ${c.room ? `<span class="c-room">${c.room}</span>`:''}
      <button class="c-del" title="刪除" onclick="event.stopPropagation();deleteCourse(${JSON.stringify(c.id)})">✕</button>`;
    chip.addEventListener('dragstart', e => {
      dragCourseId = c.id; chip.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'copy';
    });
    chip.addEventListener('dragend', () => {
      dragCourseId = null; chip.classList.remove('dragging');
    });
    chip.addEventListener('click', () => {
      pendingPickMode = c.id;
      goMain();
      toast(`點擊課表格子放入「${c.name}」`);
    });
    pool.appendChild(chip);
  });
}
function addCourse() {
  const name = document.getElementById('inName').value.trim();
  if (!name) { toast('請輸入課程名稱'); return; }
  courses.push({ id: Date.now()+Math.random(), name, room: document.getElementById('inRoom').value.trim(), colorIdx: selColorIdx });
  document.getElementById('inName').value = '';
  document.getElementById('inRoom').value = '';
  renderPool();
  toast(`已新增「${name}」`);
}

// Time slots
function renderTimeSlots() {
  const list = document.getElementById('timeSlotsList');
  list.innerHTML = '';
  timeSlots.forEach((ts, i) => {
    const row = document.createElement('div');
    row.className = 'time-row';
    row.innerHTML = `
      <span class="tr-period">${i+1}</span>
      <input type="time" value="${ts.start}" onchange="timeSlots[${i}].start=this.value;renderMain()">
      <span class="tr-sep">—</span>
      <input type="time" value="${ts.end}" onchange="timeSlots[${i}].end=this.value;renderMain()">
      <button class="tr-del" onclick="removeTimeSlot(${i})" title="刪除節次">✕</button>`;
    list.appendChild(row);
  });
}
function addTimeSlot() {
  const last = timeSlots[timeSlots.length-1];
  const [h,m] = (last?.end||'17:00').split(':').map(Number);
  const newH = h + (m >= 50 ? 1 : 0);
  const newM = m >= 50 ? 0 : m + 10;
  const fmt = v => String(v).padStart(2,'0');
  timeSlots.push({ start:`${fmt(newH)}:${fmt(newM)}`, end:`${fmt(newH+0)}:${fmt(newM+50>59?newM+50-60:newM+50)}` });
  renderTimeSlots(); renderMain();
}
function removeTimeSlot(i) {
  if (timeSlots.length <= 1) { toast('至少保留一節'); return; }
  // remove schedule entries for this slot
  Object.keys(schedule).forEach(k => { if (k.endsWith(`-${i}`)) delete schedule[k]; });
  timeSlots.splice(i, 1);
  renderTimeSlots(); renderMain();
}

// Day toggle
function renderDayToggle() {
  const wrap = document.getElementById('dayToggle');
  wrap.innerHTML = '';
  DAYS_ALL.forEach((d, i) => {
    const btn = document.createElement('button');
    btn.className = 'toggle-chip' + (activeDays.includes(i)?' on':'');
    btn.textContent = `週${d}`;
    btn.onclick = () => {
      if (activeDays.includes(i)) {
        if (activeDays.length <= 1) { toast('至少保留一天'); return; }
        activeDays = activeDays.filter(x => x !== i);
      } else {
        activeDays.push(i); activeDays.sort((a,b)=>a-b);
      }
      renderDayToggle(); renderMain();
    };
    wrap.appendChild(btn);
  });
}

// BG grid
const BACKGROUNDS = [
  { label:'原色', url:'', color:'#f5f2ec' },
  { label:'海波', url:'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1200&q=80', color:'#7394b0' },
  { label:'林間', url:'https://images.unsplash.com/photo-1448375240586-882707db888b?w=1200&q=80', color:'#7a9e7e' },
  { label:'山霧', url:'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1200&q=80', color:'#9b8fb5' },
  { label:'夜空', url:'https://images.unsplash.com/photo-1504333638930-c8787321eee0?w=1200&q=80', color:'#3d3b37' },
  { label:'和紙', url:'https://images.unsplash.com/photo-1595433706882-2de5ab8f34d7?w=1200&q=80', color:'#c8b89a' },
  { label:'茶室', url:'https://images.unsplash.com/photo-1544947950-fa07a98d237f?w=1200&q=80', color:'#a89a7c' },
];
function renderBgGrid() {
  const grid = document.getElementById('bgGrid');
  grid.innerHTML = '';
  BACKGROUNDS.forEach((bg, i) => {
    const div = document.createElement('div');
    div.className = 'bg-thumb' + (bgActive === i && !customBgDataUrl ? ' on' : '');
    if (bg.url) div.style.backgroundImage = `url('${bg.url}')`;
    else div.style.background = bg.color;
    div.innerHTML = `<div class="bg-name">${bg.label}</div>`;
    div.onclick = () => { bgActive = i; customBgDataUrl = null; applyBg(); renderBgGrid(); };
    grid.appendChild(div);
  });
  // custom upload
  const up = document.createElement('div');
  up.className = 'bg-upload-slot' + (customBgDataUrl ? ' on' : '');
  if (customBgDataUrl) {
    up.style.backgroundImage = `url('${customBgDataUrl}')`;
    up.style.backgroundSize = 'cover'; up.style.color = '#fff';
  }
  up.innerHTML = `<span class="icon">＋</span><span>自訂</span>`;
  up.onclick = () => document.getElementById('bgUpload').click();
  grid.appendChild(up);
}
function applyBg() {
  const layer = document.getElementById('bg-layer');
  const overlay = document.getElementById('bg-overlay');
  if (customBgDataUrl) {
    layer.style.backgroundImage = `url('${customBgDataUrl}')`;
    overlay.style.background = 'rgba(245,242,236,0.80)';
  } else {
    const bg = BACKGROUNDS[bgActive];
    if (bg?.url) {
      layer.style.backgroundImage = `url('${bg.url}')`;
      overlay.style.background = 'rgba(245,242,236,0.82)';
    } else {
      layer.style.backgroundImage = '';
      overlay.style.background = 'transparent';
    }
  }
}
function handleBgUpload(e) {
  const file = e.target.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    customBgDataUrl = ev.target.result;
    bgActive = -1; applyBg(); renderBgGrid(); toast('已套用自訂背景');
  };
  reader.readAsDataURL(file);
  e.target.value = '';
}

// ══════════════════════════════════════
//  COLOR PICKER BUILDER
// ══════════════════════════════════════
function buildColorPicker(containerId, getIdx, setIdx) {
  const wrap = document.getElementById(containerId);
  wrap.innerHTML = '';
  JP_COLORS.forEach((c, i) => {
    const s = document.createElement('div');
    s.className = 'jp-swatch' + (getIdx() === i ? ' sel' : '');
    s.style.background = c.bg;
    s.title = c.name;
    s.onclick = () => {
      setIdx(i);
      wrap.querySelectorAll('.jp-swatch').forEach((el,j) => el.classList.toggle('sel', j===i));
    };
    wrap.appendChild(s);
  });
}

// ══════════════════════════════════════
//  EXPORT
// ══════════════════════════════════════
function exportPNG() {
  toast('正在生成圖片…');
  const s = document.createElement('script');
  s.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';
  s.onload = () => {
    const target = document.getElementById('ttExportTarget');
    html2canvas(target, { scale:2, useCORS:true, backgroundColor:'#f5f2ec', logging:false }).then(canvas => {
      const a = document.createElement('a');
      a.download = '時間割.png'; a.href = canvas.toDataURL('image/png'); a.click();
      toast('課表已匯出！');
    });
  };
  document.head.appendChild(s);
}

// ══════════════════════════════════════
//  TOAST
// ══════════════════════════════════════
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(t._t);
  t._t = setTimeout(() => t.classList.remove('show'), 2400);
}

// ══════════════════════════════════════
//  KEYBOARD
// ══════════════════════════════════════
document.addEventListener('keydown', e => {
  if (e.key==='Escape') { closeModal(); pendingPickMode=null; }
  if (e.key==='Enter' && document.getElementById('modal').classList.contains('open')) confirmModal();
});
document.getElementById('inName').addEventListener('keydown', e => { if(e.key==='Enter') addCourse(); });

