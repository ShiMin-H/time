<script>
// ══════════════════════════════════════
//  JAPANESE PALETTE — 低飽和
// ══════════════════════════════════════
const JP_COLORS = [
  { bg:'#d4c5b0', text:'#3d3631', name:'白茶' },   // shiracha
  { bg:'#bfb59e', text:'#32291e', name:'砂色' },   // suna
